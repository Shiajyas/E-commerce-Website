<%- include("../partials/header") %>

<link rel="stylesheet" href="/chatbot/css/chat.css">

<div class="container-fluid py-4">

    <div class="chat-wrapper">

        <!-- =========================
             HEADER
        ========================== -->

        <div class="chat-header">

            <div class="header-left">

                <div class="bot-avatar">
                    <i class="fas fa-robot"></i>
                </div>

                <div>

                    <h4>AI Shopping Assistant</h4>

                    <p>
                        Ask anything about products, orders or shopping.
                    </p>

                </div>

            </div>

            <div>

                <a href="/shop" class="btn btn-light">

                    <i class="fas fa-store"></i>

                    Continue Shopping

                </a>

            </div>

        </div>

        <!-- =========================
             CHAT BODY
        ========================== -->

        <div
            id="chatBox"
            class="chat-body"
        >

            <!-- Welcome -->

            <div class="bot-message">

                <div class="bubble">

                    <div class="welcome-title">

                        👋 Hello
                        <strong>
                            <%= user ? "User" : "Guest" %>
                        </strong>

                    </div>

                    <p>
                        I'm your AI shopping assistant.
                    </p>

                    <p>I can help you with:</p>

                    <ul>

                        <li>📷 CCTV Camera Recommendation</li>

                        <li>💰 Products Under Your Budget</li>

                        <li>📦 Order Status</li>

                        <li>🔄 Return Policy</li>

                        <li>🛒 Product Comparison</li>

                        <li>📊 Product Analytics</li>

                        <li>❓ Technical Questions</li>

                    </ul>

                    <div class="quick-question">

                        Try asking:

                    </div>

                    <div class="quick-buttons">

                        <button class="quick-btn">
                            Best camera under ₹5000
                        </button>

                        <button class="quick-btn">
                            Hikvision Camera
                        </button>

                        <button class="quick-btn">
                            Compare Dahua and Hikvision
                        </button>

                        <button class="quick-btn">
                            My Orders
                        </button>

                    </div>

                </div>

            </div>

        </div>

        <!-- =========================
             TYPING
        ========================== -->

        <div
            id="typing"
            class="typing-box"
            style="display:none;"
        >

            <div class="typing-avatar">

                <i class="fas fa-robot"></i>

            </div>

            <div class="typing-bubble">

                <span></span>

                <span></span>

                <span></span>

            </div>

        </div>

        <!-- =========================
             INPUT
        ========================== -->

        <div class="chat-footer">

            <input

                type="text"

                id="message"

                placeholder="Ask about products..."

                autocomplete="off"

            >

            <button id="sendBtn">

                <i class="fas fa-paper-plane"></i>

            </button>

        </div>

    </div>

</div>

<script>

window.chatConfig = {

    sessionId: "<%= sessionId %>",

    userId: "<%= userId %>",

  

};

</script>

<script type="module" src="/chatbot/js/chat.js"></script>
